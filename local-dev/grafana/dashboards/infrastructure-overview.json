{
  "title": "Infrastructure Overview",
  "uid": "infra-overview",
  "tags": ["infrastructure", "azure-mlops"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "CPU Usage %",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "datasource": { "uid": "prometheus" },
        "expr": "100 - (avg(irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
        "legendFormat": "CPU"
      }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Memory Usage %",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "datasource": { "uid": "prometheus" },
        "expr": "(1 - node_memory_MemAvailable_bytes/node_memory_MemTotal_bytes) * 100",
        "legendFormat": "Memory"
      }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Disk Usage %",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "datasource": { "uid": "prometheus" },
        "expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"rootfs\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"rootfs\"}) * 100",
        "legendFormat": "Disk /"
      }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Running Containers",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "datasource": { "uid": "prometheus" },
        "expr": "count(container_last_seen{name!=\"\"})",
        "legendFormat": "Containers"
      }]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Active Alerts",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "datasource": { "uid": "prometheus" },
        "expr": "count(ALERTS{alertstate=\"firing\"}) or vector(0)",
        "legendFormat": "Firing"
      }]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "System Uptime",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "dtdurations" } },
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "datasource": { "uid": "prometheus" },
        "expr": "node_time_seconds - node_boot_time_seconds",
        "legendFormat": "Uptime"
      }]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "CPU Usage Over Time",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "100 - (avg by(cpu)(irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU {{ cpu }}"
        },
        {
          "datasource": { "uid": "prometheus" },
          "expr": "avg(irate(node_cpu_seconds_total{mode=\"system\"}[5m])) * 100",
          "legendFormat": "System"
        },
        {
          "datasource": { "uid": "prometheus" },
          "expr": "avg(irate(node_cpu_seconds_total{mode=\"iowait\"}[5m])) * 100",
          "legendFormat": "IO Wait"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Memory Usage Over Time",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes",
          "legendFormat": "Used"
        },
        {
          "datasource": { "uid": "prometheus" },
          "expr": "node_memory_MemAvailable_bytes",
          "legendFormat": "Available"
        },
        {
          "datasource": { "uid": "prometheus" },
          "expr": "node_memory_Cached_bytes",
          "legendFormat": "Cached"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Network I/O (bytes/sec)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "rate(node_network_receive_bytes_total{device!~\"lo|docker.*\"}[5m])",
          "legendFormat": "RX {{ device }}"
        },
        {
          "datasource": { "uid": "prometheus" },
          "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|docker.*\"}[5m])",
          "legendFormat": "TX {{ device }}"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Container CPU Usage",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [{
        "datasource": { "uid": "prometheus" },
        "expr": "rate(container_cpu_usage_seconds_total{name!=\"\"}[5m]) * 100",
        "legendFormat": "{{ name }}"
      }]
    },
    {
      "id": 11,
      "type": "table",
      "title": "Firing Alerts",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 6 },
      "options": { "sortBy": [{ "displayName": "severity" }] },
      "targets": [{
        "datasource": { "uid": "prometheus" },
        "expr": "ALERTS{alertstate=\"firing\"}",
        "instant": true,
        "legendFormat": ""
      }],
      "transformations": [
        { "id": "labelsToFields", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "Value": true, "__name__": true, "alertstate": true },
            "renameByName": { "alertname": "Alert", "severity": "Severity", "instance": "Instance", "job": "Job" }
          }
        }
      ]
    }
  ]
}
