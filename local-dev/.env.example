# =============================================================================
# Local Dev Monitoring — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.
# =============================================================================

# Grafana admin credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=ChangeMe123!   # <-- change this
GRAFANA_SECRET_KEY=supersecretkey32chars00000000000  # random 32-char string

# Slack webhook for Alertmanager (optional — leave blank to disable)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#alerts
